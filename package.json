  "devDependencies": {
    "@earendil-works/pi-ai": "^0.80.7",
    "@earendil-works/pi-coding-agent": "^0.80.7",
    "@earendil-works/pi-tui": "^0.80.7",
    "@types/node": "^24.12.4",
    "tsx": "^4.19.3",
    "typebox": "^1.1.38",
    "typescript": "^5.9.3"
